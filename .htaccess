<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Don't rewrite if it's a real file or directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite to .html if the file exists with .html extension
    RewriteCond %{REQUEST_FILENAME}.html -f
    RewriteRule ^(.+?)/?$ $1.html [L,QSA]

    # Redirect old URLs to new ones (preserve query strings)
    RewriteRule ^free-guide/?$ /guidelines [R=301,QSA,L]
    RewriteRule ^free-guide\.html/?$ /guidelines.html [R=301,QSA,L]
    RewriteRule ^single-free-guide/?$ /single-guidelines [R=301,QSA,L]
    RewriteRule ^single-free-guide\.html/?$ /single-guidelines.html [R=301,QSA,L]
</IfModule>
